# ============================================
# Academic Research Assistant - Configuration
# ============================================

# Application
APP_NAME=Academic Research Assistant
APP_VERSION=0.2.0
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./ara.db

# Redis
REDIS_URL=redis://localhost:6379/0

# ============================================
# LLM Providers - Choose one
# ============================================

# Option 1: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Option 3: MiniMax (recommended for China)
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_GROUP_ID=your-group-id

# ============================================
# SiliconFlow API (Free Embedding + Reranking)
# ============================================
# Get free API key: https://siliconflow.cn
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Embedding Model (default: BAAI/bge-m3 - best for bilingual academic)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Reranking Model (default: BAAI/bge-reranker-v2-m3)
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ============================================
# Vector Database (Weaviate - Docker based, free)
# ============================================
# Default: Weaviate (self-hosted via Docker)
VECTOR_DB_PROVIDER=weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=  # Optional for local dev

# Alternative: Pinecone (requires account)
# VECTOR_DB_PROVIDER=pinecone
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-west1

# ============================================
# PDF Parser (MinerU - Best for academic papers)
# ============================================
# Default: MinerU (requires Docker deployment)
# See: https://github.com/opendatalab/MinerU
PDF_PARSER=mineru
MINERU_HOST=http://localhost:8001

# Fallback: PyMuPDF (built-in, but may have issues with double-column layouts)
# PDF_PARSER=pymupdf

# ============================================
# Academic Database APIs
# ============================================
# Note: WOS/Scopus require institutional subscriptions
# Consider using institutional login in future versions

# Web of Science (requires API key from institution)
# WOS_API_KEY=your-wos-api-key

# Scopus (requires API key from institution)
# SCOPUS_API_KEY=your-scopus-api-key

# PubMed (free, requires NCBI account)
# PUBMED_API_KEY=your-pubmed-api-key

# EBSCOhost (requires API key from institution)
# EBSCO_API_KEY=your-ebsco-api-key

# Google Scholar (no official API, use at your own risk)
# GOOGLE_SCHOLAR_ENABLED=false

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ============================================
# File Storage
# ============================================
UPLOAD_DIR=./uploads
PDF_STORAGE_DIR=./storage/pdfs

# ============================================
# Celery (Async Tasks)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
