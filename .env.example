# Application
APP_NAME=Academic Research Assistant
APP_VERSION=0.1.0
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./ara.db

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Providers - 选择其中一个配置

# Option 1: OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=  # 可选，自定义 API 地址

# Option 2: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Option 3: MiniMax (推荐国内使用)
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_GROUP_ID=your-group-id  # 可选

# Vector Database
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-west1
WEAVIATE_URL=http://localhost:8080

# Academic Database APIs
WOS_API_KEY=...
SCOPUS_API_KEY=...
PUBMED_API_KEY=...
EBSCO_API_KEY=...
GOOGLE_SCHOLAR_ENABLED=false

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# File Storage
UPLOAD_DIR=./uploads
PDF_STORAGE_DIR=./storage/pdfs

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
